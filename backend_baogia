/* =========================
 * ENTRY POINT
 * ========================= */
function doGet(e) {
    try {
        const action = e.parameter.action || 'all'

        // GET ALL
        if (action === 'all') {
            return json(getAllSheets())
        }

        // GET ONE SHEET
        if (SHEETS[action]) {
            return json(getOneSheet(SHEETS[action]))
        }
        if (action === 'hop_dong_active') {
            return json(getActiveContracts_())
        }

        return json({ error: 'INVALID_ACTION' })
    } catch (err) {
        return json({ error: err.message })
    }
}


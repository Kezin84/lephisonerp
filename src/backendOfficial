// ─────────────────────────────────────────────────────────────
//  HELPER: lấy sheet KHACH_HANG
// ─────────────────────────────────────────────────────────────
function kh_getSheet() {
  return SpreadsheetApp.getActiveSpreadsheet().getSheetByName(KH_SHEET_NAME);
}

function kh_invalidateCache() {
  CacheService.getScriptCache().remove(KH_CACHE_KEY);
}

// ─────────────────────────────────────────────────────────────
//  HELPER: tạo mã khách hàng tự động  →  KH_YYYYMMDD_xxxxx
// ─────────────────────────────────────────────────────────────
function kh_genID() {
  const d   = new Date();
  const pad = (n, l=2) => String(n).padStart(l, "0");
  return `KH_${d.getFullYear()}${pad(d.getMonth()+1)}${pad(d.getDate())}_${pad(d.getHours())}${pad(d.getMinutes())}${pad(d.getSeconds())}`;
}

// ─────────────────────────────────────────────────────────────
//  HELPER: convert array row → object
// ─────────────────────────────────────────────────────────────
function kh_rowToObj(r) {
  const obj = {};
  KH_FIELDS.forEach((f, i) => { obj[f] = r[i] !== undefined ? r[i] : ""; });
  return obj;
}

// ─────────────────────────────────────────────────────────────
//  HELPER: convert object → array (đúng thứ tự cột)
// ─────────────────────────────────────────────────────────────
function kh_objToRow(p, existing) {
  return KH_FIELDS.map((f, i) =>
    p[f] !== undefined ? p[f] : (existing ? existing[i] : "")
  );
}

// ─────────────────────────────────────────────────────────────
//  GET khách hàng
//  Params: ten, trang_thai, cong_ty, search, limit, offset
// ─────────────────────────────────────────────────────────────
function kh_getData(params) {
  const cache = CacheService.getScriptCache();

  const filterTen     = params.ten        || null; // tìm theo tên
  const filterStatus  = params.trang_thai || null;
  const filterCongTy  = params.cong_ty    || null;
  const filterSearch  = params.search     || null; // tìm toàn text
  const filterMa      = params.ma         || null; // lấy 1 KH theo mã
  const limit         = parseInt(params.limit)  || 0;
  const offset        = parseInt(params.offset) || 0;

  const useCache = !filterTen && !filterStatus && !filterCongTy
                && !filterSearch && !filterMa && !limit;

  if (useCache) {
    const cached = cache.get(KH_CACHE_KEY);
    if (cached) return JSON.parse(cached);
  }

  const sheet   = kh_getSheet();
  const lastRow = sheet.getLastRow();

  if (lastRow < 2) {
    const empty = { status: "success", total: 0, data: [] };
    if (useCache) cache.put(KH_CACHE_KEY, JSON.stringify(empty), CACHE_TTL);
    return empty;
  }

  const values = sheet.getRange(2, 1, lastRow - 1, KH_COLS).getValues();

  let rows = values
    .filter(r => r[0] !== "")
    .map(r => kh_rowToObj(r));

  // --- filters ---
  if (filterMa)     rows = rows.filter(r => r.ma_khach_hang === filterMa);
  if (filterTen)    rows = rows.filter(r => r.ten_khach_hang.toLowerCase().includes(filterTen.toLowerCase()));
  if (filterStatus) rows = rows.filter(r => r.trang_thai.toLowerCase() === filterStatus.toLowerCase());
  if (filterCongTy) rows = rows.filter(r => r.ten_cong_ty.toLowerCase().includes(filterCongTy.toLowerCase()));
  if (filterSearch) {
    const q = filterSearch.toLowerCase();
    rows = rows.filter(r =>
      Object.values(r).some(v => String(v).toLowerCase().includes(q))
    );
  }

  const total = rows.length;
  if (limit > 0) rows = rows.slice(offset, offset + limit);

  const result = { status: "success", total, offset, limit, data: rows };
  if (useCache) cache.put(KH_CACHE_KEY, JSON.stringify(result), CACHE_TTL);
  return result;
}

// ─────────────────────────────────────────────────────────────
//  POST router
// ─────────────────────────────────────────────────────────────
function kh_postData(payload) {
  const action = (payload.action || "add").toLowerCase();
  if (action === "add")    return kh_addRow(payload);
  if (action === "update") return kh_updateRow(payload);
  if (action === "delete") return kh_deleteRow(payload);
  return { status: "error", message: "action không hợp lệ. Dùng: add | update | delete" };
}

// ─────────────────────────────────────────────────────────────
//  ADD
// ─────────────────────────────────────────────────────────────
function kh_addRow(p) {
  if (!p.ten_khach_hang) return { status: "error", message: "ten_khach_hang là bắt buộc" };

  const sheet = kh_getSheet();
  const id    = p.ma_khach_hang || kh_genID();
  p.ma_khach_hang = id;

  const row = kh_objToRow(p, null);
  sheet.appendRow(row);
  ensureTextCols_(sheet, sheet.getLastRow(), row, [3, 6, 17, 22]);
  kh_invalidateCache();
  return { status: "success", action: "add", ma_khach_hang: id };
}

// ─────────────────────────────────────────────────────────────
//  UPDATE (partial – chỉ cần truyền field muốn đổi)
// ─────────────────────────────────────────────────────────────
function kh_updateRow(p) {
  if (!p.ma_khach_hang) return { status: "error", message: "ma_khach_hang là bắt buộc để update" };

  const sheet   = kh_getSheet();
  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return { status: "error", message: "Sheet rỗng" };

  const cell = sheet.getRange(2, 1, lastRow - 1, 1).createTextFinder(p.ma_khach_hang).matchEntireCell(true).findNext();
  if (!cell) return { status: "error", message: `Không tìm thấy: ${p.ma_khach_hang}` };

  const rowNum  = cell.getRow();
  const existing = sheet.getRange(rowNum, 1, 1, KH_COLS).getValues()[0];
  const row = kh_objToRow(p, existing);
  sheet.getRange(rowNum, 1, 1, KH_COLS).setValues([row]);
  ensureTextCols_(sheet, rowNum, row, [3, 6, 17, 22]);

  kh_invalidateCache();
  return { status: "success", action: "update", ma_khach_hang: p.ma_khach_hang };
}

// ─────────────────────────────────────────────────────────────
//  DELETE
// ─────────────────────────────────────────────────────────────
function kh_deleteRow(p) {
  const id = p.ma_khach_hang || p.id;
  if (!id) return { status: "error", message: "ma_khach_hang là bắt buộc để delete" };

  const sheet   = kh_getSheet();
  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return { status: "error", message: "Sheet rỗng" };

  const cell = sheet.getRange(2, 1, lastRow - 1, 1).createTextFinder(id).matchEntireCell(true).findNext();
  if (!cell) return { status: "error", message: `Không tìm thấy: ${id}` };

  sheet.deleteRow(cell.getRow());
  kh_invalidateCache();
  return { status: "success", action: "delete", ma_khach_hang: id };
}


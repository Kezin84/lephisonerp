/**
 * Rebuild Ma_hang_lien_ket + Ten_hang_lien_ket cho TẤT CẢ hàng
 * cùng Danh_muc trong sheet hang_hoa.
 * Mỗi hàng sẽ liên kết tới tất cả hàng khác cùng danh mục.
 */
function rebuildCategoryLinks_(sh, category) {
    const cat = String(category).trim().toUpperCase()
    if (!cat) return
    
    const lastRow = sh.getLastRow()
    if (lastRow < 2) return
    
    // Đọc tất cả dữ liệu: Ma_hang(A), Ten_hang(B), Danh_muc(I)
    const data = sh.getRange(2, 1, lastRow - 1, 19).getValues() // 19 cột (A-S)
    
    // Tìm tất cả hàng cùng danh mục
    const sameCatIndices = []
    for (let i = 0; i < data.length; i++) {
        const rowCat = String(data[i][8] || '').trim().toUpperCase()
        if (rowCat === cat) {
            sameCatIndices.push(i)
        }
    }
    
    if (sameCatIndices.length < 2) return // Chỉ có 1 hoặc 0 hàng, không cần liên kết
    
    // Với mỗi hàng cùng danh mục, gán liên kết = tất cả hàng KHÁC cùng danh mục
    sameCatIndices.forEach(idx => {
        const myMa = String(data[idx][0] || '').trim()
        const otherMas = []
        const otherTens = []
        
        sameCatIndices.forEach(otherIdx => {
            if (otherIdx !== idx) {
                otherMas.push(String(data[otherIdx][0] || '').trim())
                otherTens.push(String(data[otherIdx][1] || '').trim())
            }
        })
        
        const sheetRow = idx + 2 // 1-indexed, skip header
        sh.getRange(sheetRow, 18).setValue(otherMas.join('\n'))   // Col R = Ma_hang_lien_ket
        sh.getRange(sheetRow, 19).setValue(otherTens.join('\n'))  // Col S = Ten_hang_lien_ket
    })
}

function createHangHoaBatch_(payloads) {
    if (!Array.isArray(payloads) || payloads.length === 0) return { error: 'No data' };
    const sh = getSheet_(BG_SHEETS.hang_hoa);
    const numRows = payloads.length;
    const numCols = payloads[0].length;
    
    // Ensure all payloads have the same length
    const uniformPayloads = payloads.map(p => {
       const row = new Array(numCols).fill('');
       for(let i=0; i<Math.min(p.length, numCols); i++) {
           row[i] = p[i] !== undefined ? p[i] : '';
       }
       return row;
    });

    const lastRow = sh.getLastRow();
    let existingMap = {};
    if (lastRow >= 2) {
        const data = sh.getRange(2, 1, lastRow - 1, 1).getValues();
        for (let i = 0; i < data.length; i++) {
            const ma = String(data[i][0]).trim();
            if (ma) {
                existingMap[ma] = i + 2;
            }
        }
    }

    const newRows = [];
    let updatedCount = 0;

    uniformPayloads.forEach(row => {
        const maHang = String(row[0]).trim();
        if (maHang && existingMap[maHang]) {
            const rowIdx = existingMap[maHang];
            sh.getRange(rowIdx, 1, 1, numCols).setValues([row]);
            updatedCount++;
        } else {
            newRows.push(row);
        }
    });

    if (newRows.length > 0) {
        sh.getRange(sh.getLastRow() + 1, 1, newRows.length, numCols).setValues(newRows);
    }
    return { count: newRows.length + updatedCount, updated: updatedCount, added: newRows.length };
}


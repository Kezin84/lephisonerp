// ─────────────────────────────────────────────────────────────
//  doGet  –  ?sheet=report|khach_hang  &action=get|delete  &...filters
// ─────────────────────────────────────────────────────────────
function doGet(e) {
  const params = e.parameter || {};

  // --- TÍCH HỢP BÁO GIÁ ---
  const action = params.action || "";
  const bgActions = ["all", "hang_hoa", "khach_hang", "hop_dong_tong_quat", "hop_dong_chi_tiet", "hop_dong_version", "hop_dong_active", "dieu_khoan", "po_dxmh", "chi_tiet_mua_hang", "deal_reg"];
  if (bgActions.includes(action)) {
    return bg_doGet(e);
  }
  // -------------------------

  const sheet  = (params.sheet || "report").toLowerCase();
  let result;

  try {
    if (sheet === "khach_hang") {
      result = params.action === "delete" ? kh_deleteRow(params) : kh_getData(params);
    } else if (sheet === "po_dxmh") {
      result = params.action === "delete" ? po_deleteRow(params) : po_getData(params);
    } else if (sheet === "chi_tiet_mua_hang") {
      result = params.action === "delete" ? ctmh_deleteRow(params) : ctmh_getData(params);
    } else if (sheet === "deal_reg") {
      result = params.action === "delete" ? dr_deleteRow(params) : dr_getData(params);
    } else if (sheet === "sale_report") {
      result = params.action === "delete" ? sr_deleteRow(params) : sr_getData(params);
    } else {
      result = params.action === "delete" ? deleteRow(params) : getData(params);
    }
  } catch (err) {
    result = { status: "error", message: err.message };
  }

  return ContentService
    .createTextOutput(JSON.stringify(result))
    .setMimeType(ContentService.MimeType.JSON);
}

// ─────────────────────────────────────────────────────────────
//  doPost  –  body JSON: { sheet, action, ...fields }
// ─────────────────────────────────────────────────────────────
function doPost(e) {
  const lock = LockService.getScriptLock();
  try {
    // Chờ tối đa 10 giây để lấy lock
    lock.waitLock(10000);
  } catch (err) {
    return ContentService
      .createTextOutput(JSON.stringify({ status: "error", message: "Hệ thống đang xử lý, vui lòng thử lại sau vài giây." }))
      .setMimeType(ContentService.MimeType.JSON);
  }

  try {
    // --- TÍCH HỢP BÁO GIÁ ---
    let action = (e.parameter && e.parameter.action) ? String(e.parameter.action).trim() : "";
    
    if (!action && e && e.postData && e.postData.contents) {
      try {
        const parsed = JSON.parse(e.postData.contents);
        if (parsed.action) action = String(parsed.action).trim();
      } catch (err) {}
    }

    if (
      action === "save_contract_temp" || 
      action === "save_contract_official" ||
      action === "update_contract" ||
      action === "create_dieu_khoan" ||
      action === "update_dieu_khoan" ||
      action === "delete_dieu_khoan" ||
      action === "addHangHoa" ||
      action === "addHangHoaBatch" ||
      action === "editHangHoa" ||
      action === "deleteHangHoa" ||
      action === "update_chi_tiet_dates" ||
      action === "update_contract_file"
    ) {
      // Nhả lock trước khi gọi bg_doPost (vì bg_doPost sẽ tự lấy lock riêng)
      try { lock.releaseLock() } catch (e2) {}
      return bg_doPost(e);
    }
    // -------------------------

    let result;

    try {
      const payload = JSON.parse(e.postData.contents || "{}");
      const sheet   = (payload.sheet || "report").toLowerCase();

      if (action === "upload_image" || payload.action === "upload_image") {
        try {
          var decodedData = Utilities.base64Decode(payload.data);
          var blob = Utilities.newBlob(decodedData, payload.mimeType || 'image/png', payload.filename || 'upload.png');
          var file = DriveApp.createFile(blob);
          file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
          result = { status: "success", action: "upload_image", url: file.getUrl() };
        } catch (uploadErr) {
          result = { status: "error", action: "upload_image", message: uploadErr.message };
        }
      } else if (sheet === "khach_hang") {
        result = kh_postData(payload);
      } else if (sheet === "po_dxmh") {
        result = po_postData(payload);
      } else if (sheet === "chi_tiet_mua_hang") {
        result = ctmh_postData(payload);
      } else if (sheet === "deal_reg") {
        result = dr_postData(payload);
      } else if (sheet === "sale_report") {
        result = sr_postData(payload);
      } else {
        result = postData(payload);
      }
    } catch (err) {
      result = { status: "error", message: err.message };
    }

    return ContentService
      .createTextOutput(JSON.stringify(result))
      .setMimeType(ContentService.MimeType.JSON);

  } finally {
    // Luôn nhả lock dù thành công hay lỗi
    lock.releaseLock();
  }
}



// GET ALL SHEETS (CACHED)
function getAllSheets(fresh) {
    const cache = CacheService.getScriptCache()
    const ss = SpreadsheetApp.getActiveSpreadsheet()
    const result = {}

    for (const key in BG_SHEETS) {
        const cacheKey = 'CACHE_SHEET_' + key;
        
        if (!fresh) {
            const cached = cache.get(cacheKey);
            if (cached) {
                result[key] = JSON.parse(cached);
                continue;
            }
        }

        const sh = ss.getSheetByName(BG_SHEETS[key])
        if (!sh) {
            result[key] = []
            continue
        }

        const values = sh.getDataRange().getValues()
        const data = values.length > 1 ? values.slice(1) : [];
        result[key] = data;

        // Cố gắng cache, nếu quá 100KB bỏ qua
        try {
            cache.put(cacheKey, JSON.stringify(data), 300) // cache 5 phút
        } catch (e) {
            // Ignore if payload > 100KB
        }
    }

    return result
}

// GET ONE SHEET
function getOneSheet(sheetName) {
    const ss = SpreadsheetApp.getActiveSpreadsheet()
    const sh = ss.getSheetByName(sheetName)
    if (!sh) return []

    const values = sh.getDataRange().getValues()
    return values.length > 1 ? values.slice(1) : []
}


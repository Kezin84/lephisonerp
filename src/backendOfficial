/* =========================
 * HELPERS
 * ========================= */
function parsePayload_(e) {
    // Ưu tiên payload từ form-url-encoded: payload=<json>
    if (e && e.parameter && e.parameter.payload) {
        try { return JSON.parse(e.parameter.payload) } catch (err) { return {} }
    }

    // fallback nếu gửi JSON body
    if (e && e.postData && e.postData.contents) {
        const ct = String(e.postData.type || '')
        if (ct.indexOf('application/json') >= 0) {
            try { return JSON.parse(e.postData.contents) } catch (err) { return {} }
        }
    }
    return {}
}
function saveContractVersion_(maMoi, soHopDong, maCu) {
    const shVer = getSheet_(BG_SHEETS.hop_dong_version)
    const now = Utilities.formatDate(
        new Date(),
        'Asia/Ho_Chi_Minh',
        'HH:mm:ss dd/MM/yyyy'
    )


    // 1️⃣ deactivate version cũ (nếu có)
    if (maCu) {
        const lastRow = shVer.getLastRow()
        if (lastRow >= 2) {
            const data = shVer.getRange(2, 1, lastRow - 1, 5).getValues()
            for (let i = 0; i < data.length; i++) {
                if (String(data[i][0]) === maCu) {
                    shVer.getRange(i + 2, 5).setValue(false) // is_active = FALSE
                    break
                }
            }
        }
    }

    // 2️⃣ insert version mới
    shVer.appendRow([
        maMoi,
        soHopDong,
        maCu || '',
        now,
        true
    ])
}

function toNum_(v, fallback) {
    const n = Number(v)
    return isFinite(n) ? n : (fallback || 0)
}

function getSheet_(name) {
    const ss = SpreadsheetApp.getActiveSpreadsheet()
    const sh = ss.getSheetByName(name)
    if (!sh) throw new Error('SHEET_NOT_FOUND: ' + name)
    return sh
}

function appendRows_(sh, rows2d) {
    if (!rows2d || !rows2d.length) return 0
    const startRow = sh.getLastRow() + 1
    const numRows = rows2d.length
    const numCols = rows2d[0].length
    sh.getRange(startRow, 1, numRows, numCols).setValues(rows2d)
    return numRows
}

function clearGetCache_() {
    try {
        CacheService.getScriptCache().remove('GET_ALL_SHEETS')
    } catch (e) { }
}
/* =========================

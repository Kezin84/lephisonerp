      item.created_time = `${pad(now.getDate())}/${pad(now.getMonth()+1)}/${now.getFullYear()} ${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;
    }
    return SR_FIELDS.map(f => item[f] !== undefined ? item[f] : '');
  });
  const startRow = sh.getLastRow() + 1;
  sh.getRange(startRow, 1, rows2d.length, SR_COLS).setValues(rows2d);
  ensureTextColsBulk_(sh, startRow, rows2d, [10]);
  sr_invalidate_(); clearGetCache_();
  return {status:"success",action:"add_bulk",count:rows2d.length};
}

function sr_updateRow(p) {
  const id = p.ID;
  if (!id) return {status:"error",message:"ID bắt buộc"};
  const sh = sr_getSheet_();
  const lastRow = sh.getLastRow();
  if (lastRow < 2) return {status:"error",message:"Sheet rỗng"};
  const cell = sh.getRange(2, 1, lastRow - 1, 1).createTextFinder(id).matchEntireCell(true).findNext();
  if (!cell) return {status:"error",message:"Không tìm: "+id};
  const rowNum = cell.getRow();
  const existing = sh.getRange(rowNum,1,1,SR_COLS).getValues()[0];
  const row = SR_FIELDS.map((f, i) => p[f] !== undefined ? p[f] : existing[i]);
  sh.getRange(rowNum,1,1,SR_COLS).setValues([row]);
  ensureTextCols_(sh, rowNum, row, [10]);
  sr_invalidate_(); clearGetCache_();
  return {status:"success",action:"update",ID:id};
}

function sr_deleteRow(p) {
  const id = p.ID || p.id;
  if (!id) return {status:"error",message:"ID bắt buộc"};
  const sh = sr_getSheet_();
  const lastRow = sh.getLastRow();
  if (lastRow < 2) return {status:"error",message:"Sheet rỗng"};
  const cell = sh.getRange(2, 1, lastRow - 1, 1).createTextFinder(id).matchEntireCell(true).findNext();
  if (!cell) return {status:"error",message:"Không tìm: "+id};
  sh.deleteRow(cell.getRow());
  sr_invalidate_(); clearGetCache_();
  return {status:"success",action:"delete",ID:id};
}

function sr_deleteByContract(p) {
  if (!p.ma_hop_dong) return {status:"error",message:"ma_hop_dong bắt buộc"};
  const sh = sr_getSheet_();
  const lastRow = sh.getLastRow();
  if (lastRow < 2) return {status:"success",action:"delete_by_contract",deleted:0};
  const data = sh.getRange(2,1,lastRow-1,SR_COLS).getValues();
  let deleted = 0;
  for (let i = data.length - 1; i >= 0; i--) {
    if (String(data[i][2]) === p.ma_hop_dong) {
      sh.deleteRow(i + 2);
      deleted++;
    }
  }
  sr_invalidate_(); clearGetCache_();
  return {status:"success",action:"delete_by_contract",deleted};
}

/**
 * Tìm ma_hop_dong_goc của 1 hợp đồng cũ theo ma_hop_dong
 * Quét cột A (ma_hop_dong) và cột AG (index 32 = ma_hop_dong_goc)
 */
function getMaHopDongGoc_(maHopDong) {
    if (!maHopDong) return ''
    const sh = getSheet_(BG_SHEETS.hop_dong_tong_quat)
    const lastRow = sh.getLastRow()
    if (lastRow < 2) return ''
    const data = sh.getRange(2, 1, lastRow - 1, HD_TONG_COLS).getValues()
    for (var i = data.length - 1; i >= 0; i--) {
        if (String(data[i][0]).trim() === String(maHopDong).trim()) {
            return String(data[i][32] || '').trim()
        }
    }
    return ''
}

/**
 * Quét tất cả rows có ma_hop_dong_goc = maGoc
 * và isCompleted != true → set isCompleted = true
 * NGOẠI TRỪ row có ma_hop_dong = excludeMaHD (bản chính thức vừa tạo)
 */
function markDraftsAsCompleted_(shTong, maGoc, excludeMaHD) {
    if (!maGoc) return 0
    const lastRow = shTong.getLastRow()
    if (lastRow < 2) return 0
    const data = shTong.getRange(2, 1, lastRow - 1, HD_TONG_COLS).getValues()
    var count = 0
    for (var i = 0; i < data.length; i++) {
        var rowMaGoc = String(data[i][32] || '').trim()
        var rowMaHD = String(data[i][0] || '').trim()
        var rowCompleted = data[i][33]
        if (rowMaGoc === maGoc && rowMaHD !== excludeMaHD && rowCompleted !== true && String(rowCompleted) !== 'true' && String(rowCompleted) !== 'TRUE') {
            shTong.getRange(i + 2, 34).setValue(true) // cột AH = isCompleted
            count++
        }
    }
    return count
}

/* =========================
 * CONST COL COUNT (SCHEMA)
 * ========================= */
const HD_TONG_COLS = 36 // +2 cols: [34]ten_file [35]link_file
const HD_CT_COLS = 30 // +2 cols: [28]start_date [29]end_date
const HD_VER_COLS = 5 // ✅ version sheet cols

function normalizeRow_(arr, cols) {
    var row = Array.isArray(arr) ? arr.slice(0, cols) : []
    while (row.length < cols) row.push('')
    return row
}

function normalizeRows2D_(rows, cols) {
    return (Array.isArray(rows) ? rows : []).map(function (r) {
        return normalizeRow_(r, cols)
    })
}
function getHangHoaTiGiaMap_() {
    const cache = CacheService.getScriptCache()
    const k = 'HH_TIGIA_MAP'
    const cached = cache.get(k)
    if (cached) return JSON.parse(cached)

    const sh = getSheet_(BG_SHEETS.hang_hoa)
    const lastRow = sh.getLastRow()
    const map = {}

    if (lastRow >= 2) {
        // đọc từ A..P (16 cột) để lấy Ma_hang và Ti_gia
        const values = sh.getRange(2, 1, lastRow - 1, 16).getValues()
        for (let i = 0; i < values.length; i++) {
            const ma = String(values[i][0] || '').trim()        // col A
            const tg = toNum_(values[i][15], 1)                 // col P (index 15)
            if (ma) map[ma] = tg
        }
    }

    cache.put(k, JSON.stringify(map), 300)
    return map
}

function getTiGiaByMaHang_(maHang, hhMap) {
    const ma = String(maHang || '').trim()
    if (!ma) return 25400
    if (hhMap && typeof hhMap[ma] !== 'undefined') {
        const val = toNum_(hhMap[ma], 25400)
        return val > 1 ? val : 25400
    }
    // fallback
    return 25400
}
function buildContractDetailRows_(ctRows, trangThaiHopDong) {
    const hhMap = getHangHoaTiGiaMap_()

    return (Array.isArray(ctRows) ? ctRows : []).map(function (r) {
        let row = normalizeRow_(r, HD_CT_COLS)

        // Ma_hang index 2
        const maHang = row[2]

        // Don_vi_tien_te index 15: giữ FE gửi gì thì giữ
        const dvtien = String(row[15] || '').trim()
        row[15] = dvtien

        // ✅ IF: nếu FE đã chuyển sang VND thì giữ Ti_gia = 1 (không overwrite theo hang_hoa)
        if (dvtien.toUpperCase() === 'VND') {
            row[16] = 1
        } else {
            // Ti_gia ép theo hang_hoa
            const tiGia = getTiGiaByMaHang_(maHang, hhMap)
            row[16] = toNum_(tiGia, 1)
        }

        // Trang_thai_hop_dong ép theo nút (index 19)
        row[19] = trangThaiHopDong || ''

        // So_luong index 18
        row[18] = Math.max(1, toNum_(row[18], 1))

        // ép số cho sạch
        row[13] = toNum_(row[13], 0) // Gia_tieu_chuan
        row[14] = toNum_(row[14], 0) // Don_gia
        row[17] = toNum_(row[17], 0) // Thue_VAT

        return row
    })
}


function patchTongQuatCurrencyTiGia_(hdRow, ctRows) {
    hdRow = normalizeRow_(hdRow, HD_TONG_COLS)

    let cur = ''
    if (Array.isArray(ctRows) && ctRows.length) {
        const first = ctRows[0]
        if (Array.isArray(first)) cur = String(first[15] || '').trim()
    }

    const curUp = (cur || String(hdRow[17] || 'VND')).trim().toUpperCase()

    // Nếu USD => nhân với tỉ giá để quy về VND
    const tiGia = (curUp === 'VND') ? 1 : toNum_(getContractTiGiaFromCT_(ctRows), 1)
    
    if (curUp === 'USD') {
        hdRow[5] = toNum_(hdRow[5], 0) * tiGia  // truoc_thue
        hdRow[6] = toNum_(hdRow[6], 0) * tiGia  // vat
        hdRow[7] = toNum_(hdRow[7], 0) * tiGia  // sau_thue
        hdRow[9] = toNum_(hdRow[9], 0) * tiGia  // tong_cong
        hdRow[20] = toNum_(hdRow[20], 0) * tiGia // tong_gia_thuc_te
        
        hdRow[25] = toNum_(hdRow[25], 0) * tiGia // chiet_khau_tong_truoc_thue
        hdRow[27] = toNum_(hdRow[27], 0) * tiGia // thue_chenh_lech_gia
        hdRow[29] = toNum_(hdRow[29], 0) * tiGia // chenh_lech_gia
        hdRow[30] = toNum_(hdRow[30], 0) * tiGia // con_lai
        hdRow[31] = toNum_(hdRow[31], 0) * tiGia // tong_chiet_khau
    }

    // Luôn lưu dưới dạng VND trong hop_dong_tong_quat
    hdRow[17] = 'VND'
    hdRow[18] = 1

    return hdRow
}

/* =========================
 * GET CONTRACT TIGIA (dùng update KH)
 * - lấy Ti_gia theo Ma_hang của dòng CT đầu tiên
 * ========================= */
function getContractTiGiaFromCT_(ctRows) {
    if (!Array.isArray(ctRows) || ctRows.length < 1) return 1
    const first = ctRows[0]

    const cur = Array.isArray(first) ? String(first[15] || '').trim().toUpperCase() : ''
    if (cur === 'VND') return 1

    const maHang = Array.isArray(first) ? first[2] : ''
    const hhMap = getHangHoaTiGiaMap_()
    return getTiGiaByMaHang_(maHang, hhMap)
}
/* =========================
 * SAVE CONTRACT TEMP
 * ========================= */
function saveContractTemp_(payload) {
    let hdRow = payload.hd_tong_quat_row
    const ctRows = payload.hd_chi_tiet_rows

    if (!Array.isArray(hdRow) || hdRow.length < 17) throw new Error('INVALID_hd_tong_quat_row')
    if (!Array.isArray(ctRows) || ctRows.length < 1) throw new Error('INVALID_hd_chi_tiet_rows')

    hdRow = normalizeRow_(hdRow, HD_TONG_COLS)
    hdRow[14] = 'Chưa thanh toán đủ'
    hdRow[15] = 'Tạm'

    // ✅ ma_hop_dong_goc: lấy từ bản cũ, nếu không có → chính nó
    const maCu = String(hdRow[19] || '').trim()
    if (maCu) {
        const gocFromOld = getMaHopDongGoc_(maCu)
        hdRow[32] = gocFromOld || String(hdRow[0])
    } else {
        hdRow[32] = String(hdRow[0]) // bản đầu tiên → gốc = chính nó
    }
    // ✅ isCompleted: bản tạm mới tạo luôn = false
    hdRow[33] = false

    // ✅ set Don_vi_tien_te + Ti_gia cho tổng quát
    hdRow = patchTongQuatCurrencyTiGia_(hdRow, ctRows)

    // ✅ Cong_no_cu lấy từ KH (cột N) trước khi append
    const maKH = String(hdRow[2] || '').trim()
    if (!maKH) throw new Error('MISSING_ma_khach_hang')
    const shKH = getSheet_(BG_SHEETS.khach_hang)
    hdRow[13] = getCustomerCongNoVND_(shKH, maKH)

    const shTong = getSheet_(BG_SHEETS.hop_dong_tong_quat)
    const shCT = getSheet_(BG_SHEETS.hop_dong_chi_tiet)

    shTong.appendRow(hdRow)

    // ✅ VERSIONING
    const maMoi = String(hdRow[0])
    const soHD = String(hdRow[1])
    saveContractVersion_(maMoi, soHD, maCu)

    const fixedCT = buildContractDetailRows_(ctRows, 'Tạm')
    appendRows_(shCT, fixedCT)

    clearGetCache_()
    return { appended_tong_quat: 1, appended_chi_tiet: fixedCT.length }
}


/* =========================
 * SAVE CONTRACT OFFICIAL
 * ========================= */
function saveContractOfficial_(payload) {
    let hdRow = payload.hd_tong_quat_row
    const ctRows = payload.hd_chi_tiet_rows
    const maKH = String(payload.ma_khach_hang || '').trim()
    const tongSauThue = toNum_(payload.tong_sau_thue, 0)

    if (!Array.isArray(hdRow) || hdRow.length < 17) throw new Error('INVALID_hd_tong_quat_row')
    if (!Array.isArray(ctRows) || ctRows.length < 1) throw new Error('INVALID_hd_chi_tiet_rows')
    if (!maKH) throw new Error('MISSING_ma_khach_hang')
    if (tongSauThue <= 0) throw new Error('INVALID_tong_sau_thue')

    hdRow = normalizeRow_(hdRow, HD_TONG_COLS)
    hdRow[14] = 'Chưa thanh toán đủ'
    hdRow[15] = 'Chính thức'

    // ✅ ma_hop_dong_goc: lấy từ bản cũ, nếu không có → chính nó
    const maCu = String(hdRow[19] || '').trim()
    if (maCu) {
        const gocFromOld = getMaHopDongGoc_(maCu)
        hdRow[32] = gocFromOld || String(hdRow[0])
    } else {
        hdRow[32] = String(hdRow[0])
    }
    // ✅ isCompleted: bản chính thức = true (đã hoàn thành)
    hdRow[33] = true

    // ✅ set Don_vi_tien_te + Ti_gia cho tổng quát
    hdRow = patchTongQuatCurrencyTiGia_(hdRow, ctRows)

    const shTong = getSheet_(BG_SHEETS.hop_dong_tong_quat)
    const shCT = getSheet_(BG_SHEETS.hop_dong_chi_tiet)
    const shKH = getSheet_(BG_SHEETS.khach_hang)

    // ✅ UPDATE KH: luôn quy về VND
    const curUp = String(hdRow[17] || 'VND').trim().toUpperCase()
    const tiGiaContract = (curUp === 'VND') ? 1 : toNum_(hdRow[18], 1)
    const addValueVND = toNum_(hdRow[7], 0)

    // 1) update KH trước
    const updated = updateCustomerTotals_(shKH, maKH, addValueVND)

    // 2) Cong_no_cu = công nợ mới (SAU KHI update)
    hdRow[13] = toNum_(updated.Cong_no_chua_thanh_toan, 0)

    // 3) rồi mới append hop_dong_tong_quat + chi_tiet
    shTong.appendRow(hdRow)

    // ✅ VERSIONING
    const maMoi = String(hdRow[0])
    const soHD = String(hdRow[1])
    saveContractVersion_(maMoi, soHD, maCu)

    // ✅ ẨN TẤT CẢ BẢN TẠM cùng ma_hop_dong_goc → isCompleted = true
    const maGoc = String(hdRow[32])
    markDraftsAsCompleted_(shTong, maGoc, maMoi)

    const fixedCT = buildContractDetailRows_(ctRows, 'Chính thức')
    appendRows_(shCT, fixedCT)

    clearGetCache_()
    return {
        appended_tong_quat: 1,
        appended_chi_tiet: fixedCT.length,
        currency: curUp,
        ti_gia_contract: tiGiaContract,
        add_value_vnd: addValueVND,
        customer_updated: updated,
        cong_no_cu_saved: hdRow[13],
        drafts_completed_for: maGoc
    }
}

/* =========================
 * UPDATE CONTRACT (in-place)
 * - Update row cũ trong hop_dong_tong_quat theo ma_hop_dong
 * - Xóa tất cả rows cũ trong hop_dong_chi_tiet theo ma_hop_dong, thay bằng rows mới
 * - KHÔNG cộng dồn công nợ khách hàng (vì đã cộng lần đầu khi tạo)
 * ========================= */
function updateContract_(payload) {
    var hdRow = payload.hd_tong_quat_row
    var ctRows = payload.hd_chi_tiet_rows
    var maHD = String(payload.ma_hop_dong || '').trim()

    if (!maHD) throw new Error('MISSING_ma_hop_dong')
    if (!Array.isArray(hdRow) || hdRow.length < 17) throw new Error('INVALID_hd_tong_quat_row')
    if (!Array.isArray(ctRows) || ctRows.length < 1) throw new Error('INVALID_hd_chi_tiet_rows')

    hdRow = normalizeRow_(hdRow, HD_TONG_COLS)
    hdRow[14] = 'Chưa thanh toán đủ'
    hdRow[15] = 'Chính thức'

    // set Don_vi_tien_te + Ti_gia cho tổng quát
    hdRow = patchTongQuatCurrencyTiGia_(hdRow, ctRows)

    var shTong = getSheet_(BG_SHEETS.hop_dong_tong_quat)
    var shCT = getSheet_(BG_SHEETS.hop_dong_chi_tiet)

    // ── 1) UPDATE hop_dong_tong_quat: tìm row theo ma_hop_dong (cột A) ──
    var tongLastRow = shTong.getLastRow()
    var tongFoundRow = -1
    if (tongLastRow >= 2) {
        var tongData = shTong.getRange(2, 1, tongLastRow - 1, 1).getValues()
        for (var i = 0; i < tongData.length; i++) {
            if (String(tongData[i][0] || '').trim() === maHD) {
                tongFoundRow = i + 2
                // Không break, lấy row cuối cùng (mới nhất) nếu có duplicate
            }
        }
    }

    if (tongFoundRow === -1) {
        // Nếu chưa có row cũ -> append mới (fallback cho trường hợp lần đầu)
        shTong.appendRow(hdRow)
    } else {
        // Update in-place row cũ
        shTong.getRange(tongFoundRow, 1, 1, HD_TONG_COLS).setValues([hdRow])
    }

    // ── 2) UPDATE hop_dong_chi_tiet: xóa rows cũ, thay bằng rows mới ──
    var ctLastRow = shCT.getLastRow()
    if (ctLastRow >= 2) {
        var ctData = shCT.getRange(2, 1, ctLastRow - 1, 1).getValues()
        // Xóa từ dưới lên để không bị lệch index
        for (var j = ctData.length - 1; j >= 0; j--) {
            if (String(ctData[j][0] || '').trim() === maHD) {
                shCT.deleteRow(j + 2)
            }
        }
    }

    // Append chi tiết mới
    var fixedCT = buildContractDetailRows_(ctRows, 'Chính thức')
    appendRows_(shCT, fixedCT)

    clearGetCache_()
    return {
        updated_tong_quat: tongFoundRow !== -1 ? 1 : 0,
        appended_tong_quat: tongFoundRow === -1 ? 1 : 0,
        replaced_chi_tiet: fixedCT.length,
        ma_hop_dong: maHD
    }
}

/* =========================
 * UPDATE CHI TIET DATES (start_date, end_date)
 * payload: { ma_hop_dong, ma_hang, start_date, end_date }
 * ========================= */
function updateChiTietDates_(payload) {
    var maHD = String(payload.ma_hop_dong || '').trim()
    if (!maHD) throw new Error('MISSING_ma_hop_dong')

    var items = payload.items;
    if (!items && payload.ma_hang) {
        items = [{
            ma_hang: payload.ma_hang,
            start_date: payload.start_date,
            end_date: payload.end_date
        }];
    }

    if (!Array.isArray(items) || items.length === 0) {
        return { updated: 0, ma_hop_dong: maHD }
    }

    var sh = getSheet_(BG_SHEETS.hop_dong_chi_tiet)
    var lastRow = sh.getLastRow()
    if (lastRow < 2) throw new Error('SHEET_EMPTY')

    var data = sh.getRange(2, 1, lastRow - 1, HD_CT_COLS).getValues()
    var updated = 0

    var itemsMap = {}
    for (var j = 0; j < items.length; j++) {
        var mh = String(items[j].ma_hang || '').trim()
        if (mh) {
            itemsMap[mh] = items[j]
        }
    }

    for (var i = 0; i < data.length; i++) {
        var rowMaHD = String(data[i][0] || '').trim()
        if (rowMaHD === maHD) {
            var rowMaHang = String(data[i][2] || '').trim()
            if (itemsMap[rowMaHang]) {
                var itemUpdate = itemsMap[rowMaHang]
                sh.getRange(i + 2, 29).setValue(itemUpdate.start_date || '')
                sh.getRange(i + 2, 30).setValue(itemUpdate.end_date || '')
                updated++
            }
        }
    }

    return { updated: updated, ma_hop_dong: maHD }
}

/* =========================
 * UPDATE CONTRACT FILE (ten_file, link_file)
 * payload: { ma_hop_dong, ten_file, link_file }
 * ========================= */
function updateContractFile_(payload) {
    var maHD = String(payload.ma_hop_dong || '').trim()
    var tenFile = String(payload.ten_file || '')
    var linkFile = String(payload.link_file || '')

    if (!maHD) throw new Error('MISSING_ma_hop_dong')

    var sh = getSheet_(BG_SHEETS.hop_dong_tong_quat)
    var lastRow = sh.getLastRow()
    if (lastRow < 2) throw new Error('SHEET_EMPTY')

    var data = sh.getRange(2, 1, lastRow - 1, 1).getValues()
    var updated = 0

    for (var i = data.length - 1; i >= 0; i--) {
        if (String(data[i][0] || '').trim() === maHD) {
            // col 35 = ten_file (index 34), col 36 = link_file (index 35)
            sh.getRange(i + 2, 35).setValue(tenFile)
            sh.getRange(i + 2, 36).setValue(linkFile)
            updated++
            break // chỉ update row mới nhất
        }
    }

    return { updated: updated, ma_hop_dong: maHD }
}

function updateCustomerTotals_(shKH, maKH, addValue) {
    const lastRow = shKH.getLastRow()
    if (lastRow < 2) throw new Error('KH_EMPTY')

    const data = shKH.getRange(2, 1, lastRow - 1, 1).getValues() // cột A từ row2
    let foundRow = -1
    for (let i = 0; i < data.length; i++) {
        if (String(data[i][0] || '').trim() === maKH) {
            foundRow = i + 2
            break
        }
    }
    if (foundRow === -1) return {} // Gracefully handle unknown customers

    // Tong_chi_tieu = col 13 (M), Cong_no_chua_thanh_toan = col 14 (N)
    const curTongChiTieu = toNum_(shKH.getRange(foundRow, 13).getValue(), 0)
    const curCongNo = toNum_(shKH.getRange(foundRow, 14).getValue(), 0)

    shKH.getRange(foundRow, 13).setValue(curTongChiTieu + addValue)
    shKH.getRange(foundRow, 14).setValue(curCongNo + addValue)

    return { row: foundRow, Tong_chi_tieu: curTongChiTieu + addValue, Cong_no_chua_thanh_toan: curCongNo + addValue }
}

function findCustomerRow_(shKH, maKH) {
    const lastRow = shKH.getLastRow()
    if (lastRow < 2) throw new Error('KH_EMPTY')

    const data = shKH.getRange(2, 1, lastRow - 1, 1).getValues() // col A
    for (let i = 0; i < data.length; i++) {
        if (String(data[i][0] || '').trim() === String(maKH || '').trim()) return i + 2
    }
    return -1
}

function getCustomerCongNoVND_(shKH, maKH) {
    const r = findCustomerRow_(shKH, maKH)
    if (r === -1) return 0 // Gracefully return 0 debt for unknown customers
    // Cong_no_chua_thanh_toan = col N = 14
    return toNum_(shKH.getRange(r, 14).getValue(), 0)
}

function getActiveContracts_() {
    const shVer = getSheet_(BG_SHEETS.hop_dong_version)
    const shHD = getSheet_(BG_SHEETS.hop_dong_tong_quat)

    const verData = shVer.getDataRange().getValues().slice(1)
    const activeSet = new Set(
        verData
            .filter(r => r[4] === true)
            .map(r => String(r[0]))
    )

    const hdData = shHD.getDataRange().getValues().slice(1)
    return hdData.filter(r => activeSet.has(String(r[0])))
}


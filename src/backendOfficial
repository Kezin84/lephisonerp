function po_genID_() {
  const d = new Date(), pad = (n,l=2) => String(n).padStart(l,'0');
  return `PO_${d.getFullYear()}${pad(d.getMonth()+1)}${pad(d.getDate())}_${pad(d.getHours())}${pad(d.getMinutes())}${pad(d.getSeconds())}${pad(d.getMilliseconds(),3)}`;
}

function po_getData(params) {
  const cache = CacheService.getScriptCache();
  const filterMa = params.ma_hop_dong || params.ma || null;
  const filterSoPO = params.so_po || null;
  const filterSearch = params.search || null;
  const filterStatus = params.trang_thai || null;
  const limit = parseInt(params.limit) || 0;
  const offset = parseInt(params.offset) || 0;
  const useCache = !filterMa && !filterSoPO && !filterSearch && !filterStatus && !limit;

  if (useCache) { const c = cache.get(PO_CACHE); if (c) return JSON.parse(c); }

  const sh = po_getSheet_();
  const lastRow = sh.getLastRow();
  if (lastRow < 2) { const e = {status:"success",total:0,data:[]}; if(useCache) cache.put(PO_CACHE,JSON.stringify(e),CACHE_TTL); return e; }

  const values = sh.getRange(2,1,lastRow-1,PO_COLS).getValues();
  let rows = values.filter(r => r[0] !== '').map(r => generic_rowToObj_(r, PO_FIELDS));

  if (filterMa) rows = rows.filter(r => r.ma_hop_dong === filterMa);
  if (filterSoPO) rows = rows.filter(r => String(r.so_po).toLowerCase().includes(filterSoPO.toLowerCase()));
  if (filterStatus) rows = rows.filter(r => String(r.trang_thai_don_hang).toLowerCase() === filterStatus.toLowerCase());

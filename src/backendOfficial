// ║         DATE FORMATTING HELPER                            ║
// ╚═══════════════════════════════════════════════════════════╝
function formatDateDDMMYYYY_(value) {
  if (!value) return '';
  if (value instanceof Date) {
    const pad = n => String(n).padStart(2, '0');
    return `${pad(value.getDate())}/${pad(value.getMonth()+1)}/${value.getFullYear()}`;
  }
  const num = Number(value);
  if (isFinite(num) && num > 30000 && num < 60000) {
    const d = new Date((num - 25569) * 86400 * 1000);
    const pad = n => String(n).padStart(2, '0');
    return `${pad(d.getDate())}/${pad(d.getMonth()+1)}/${d.getFullYear()}`;
  }
  return String(value);
}

function formatDateCols_(row, indices) {
  indices.forEach(i => { if (i < row.length && row[i]) row[i] = formatDateDDMMYYYY_(row[i]); });
  return row;
}

function generic_rowToObj_(r, fields) {
  const obj = {};
  fields.forEach((f, i) => { obj[f] = r[i] !== undefined ? r[i] : ''; });
  return obj;
}

function generic_objToRow_(p, fields, existing) {
  return fields.map((f, i) => p[f] !== undefined ? p[f] : (existing ? existing[i] : ''));
}

// Đảm bảo các cột phone/text giữ số 0 đầu (format text '@')
function ensureTextCols_(sh, rowNum, row, colIndices) {
  colIndices.forEach(ci => {
    const cell = sh.getRange(rowNum, ci + 1); // 1-indexed
    cell.setNumberFormat('@');
    const val = row[ci];
    if (val !== undefined && val !== '') cell.setValue(String(val));
  });
}

// Bulk version: format text cols for multiple rows
function ensureTextColsBulk_(sh, startRow, rows2d, colIndices) {
  if (!rows2d.length || !colIndices.length) return;
  colIndices.forEach(ci => {
    const range = sh.getRange(startRow, ci + 1, rows2d.length, 1);
    range.setNumberFormat('@');
    const vals = rows2d.map(r => [String(r[ci] || '')]);
    range.setValues(vals);
  });
}

